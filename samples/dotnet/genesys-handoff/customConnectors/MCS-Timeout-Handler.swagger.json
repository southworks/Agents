{
  "swagger": "2.0",
  "info": {
    "title": "MCS-Timeout-Handler",
    "description": "Custom connector template for timeout-triggered conversation reset. Update host and OAuth settings for your environment before importing. Required updates: host, OAuth authorizationUrl, OAuth tokenUrl, and OAuth scope/app ID URI.",
    "version": "1.0"
  },
  "host": "YOUR_PUBLIC_HOSTNAME",
  "basePath": "/",
  "schemes": [
    "https"
  ],
  "consumes": [],
  "produces": [],
  "paths": {
    "/api/conversations/reset": {
      "post": {
        "responses": {
          "200": {
            "description": "Conversation reset accepted or completed.",
            "schema": {
              "type": "object"
            }
          },
          "400": {
            "description": "Bad request. ConversationId is missing.",
            "schema": {
              "type": "object"
            }
          },
          "409": {
            "description": "Conflict. Conversation cannot be reset (for example, escalated conversation).",
            "schema": {
              "type": "object"
            }
          },
          "500": {
            "description": "Server error while attempting reset.",
            "schema": {
              "type": "object"
            }
          }
        },
        "summary": "Reset conversation on timeout",
        "description": "Calls the relay bot reset endpoint. Keep this path unchanged. Configure auth and host values for your tenant/environment.",
        "operationId": "resetConversationOnTimeout",
        "parameters": [
          {
            "name": "Content-Type",
            "in": "header",
            "required": false,
            "type": "string",
            "default": "application/json"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "conversationId"
              ],
              "properties": {
                "conversationId": {
                  "type": "string",
                  "description": "Required. Copilot Studio (MCS) conversation ID to reset."
                },
                "message": {
                  "type": "string",
                  "description": "Optional. Custom message sent to the Teams conversation before reset."
                }
              }
            }
          }
        ]
      }
    }
  },
  "definitions": {},
  "parameters": {},
  "responses": {},
  "security": [
    {
      "oauth2-auth": [
        "api://YOUR_APP_ID_URI/.default"
      ]
    }
  ],
  "tags": [],
  "securityDefinitions": {
    "oauth2-auth": {
      "type": "oauth2",
      "flow": "accessCode",
      "tokenUrl": "https://login.windows.net/common/oauth2/authorize",
      "scopes": {
        "api://YOUR_APP_ID_URI/.default": "Delegated access to the timeout handler API. Replace with your App ID URI scope."
      },
      "authorizationUrl": "https://login.microsoftonline.com/common/oauth2/authorize"
    }
  }
}