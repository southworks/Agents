{
  "TokenValidation": {
    "Enabled": true,
    "Audiences": [
      "{{ClientID}}"
    ],
    "TenantId": "{{TenantID}}"
  },

  "AgentApplication": {
    "StartTypingTimer": true,
    "RemoveRecipientMention": false,
    "NormalizeMentions": false,

    "UserAuthorization": {
      "DefaultHandlerName": "mcs",
      "AutoSignIn": true,
      "Handlers": {
        "mcs": {
          "Settings": {
            "AzureBotOAuthConnectionName": "{{AzureBotOAuthConnectionName}}",
            "OBOConnectionName": "MCSConnection" // OBOScopes are resolved at runtime
          }
        }
      }
    }
  },

  "CopilotStudioAgent": {
    "EnvironmentId": "null",
    "SchemaName": "null"
  },

  "Connections": {
    "ServiceConnection": {
      "Settings": {
        // this is the AuthType for the connection, valid values can be found in Microsoft.Agents.Authentication.Msal.Model.AuthTypes.  The default is ClientSecret.
        "AuthType": "ClientSecret",
        "AuthorityEndpoint": "https://login.microsoftonline.com/{{TenantId}}",
        "ClientId": "{{ClientID}}",
        "ClientSecret": "{{ClientSecret}}",
        "Scopes": [
          "https://api.botframework.com/.default"
        ]
      }
    },
    "MCSConnection": {
      "Settings": {
        "AuthType": "ClientSecret",
        "AuthorityEndpoint": "https://login.microsoftonline.com/{{TenantId}}",
        "ClientId": "{{ClientID}}", // this is the Client ID used for the exchange.
        "ClientSecret": "{{ClientSecret}}"
      }
    }
  },

  "Genesys": {
    "OauthUrl": "{{GenesysOauthUrl}}",
    "ApiUrl": "{{GenesysApiUrl}}",
    "IntegrationId": "{{GenesysIntegrationId}}",
    "ClientId": "{{GenesysClientId}}",
    "ClientSecret": "{{GenesysClientSecret}}",
    "WebhookSignatureSecret": "{{OutboundNotificationWebhookSignatureSecretToken}}", // Optional: outboundNotificationWebhookSignatureSecretToken from Genesys integration
    "EnableNotifications": true, // Enable WebSocket notifications for agent disconnect detection
    "AgentDisconnectedMessage": "The live agent has left the conversation. You are now back with the bot.",
    "AgentDisconnectedClientMessage": "The live agent has disconnected the chat. You are now back with the bot.",
    "AgentDisconnectedTimeoutMessage": "The live chat timed out due to inactivity. You are now back with the bot.",
    "AgentDisconnectedErrorMessage": "The live chat ended because of an error. You are now back with the bot.",
    "EndLiveChatMessage": "End chat with agent",
    "ResetConversationMessage": "The conversation has been reset by the system. Please start a new conversation if you need further assistance."
  },
  "TeamsMessages": {
    "SignInFailureFormat": "SignIn failed with '{0}': {1}/{2}",
    "MessageSendErrorMessage": "Sorry, there was a problem sending your message to the live agent. Please try again.",
    "EscalationErrorMessage": "Sorry, we couldn't connect you to a live agent at this time. Please try again later.",
    "DisconnectFromLiveAgentMessage": "You have ended the chat with the live agent.",
    "SignOutMessage": "You have signed out",
    "LiveAgentMessagePrefix": "[Live Agent] - "
  },

  "ConnectionsMap": [
    {
      "ServiceUrl": "*",
      "Connection": "ServiceConnection"
    }
  ]
}