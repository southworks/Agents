# rename to .env
connections__serviceConnection__settings__clientId= # App ID of the App Registration
connections__serviceConnection__settings__clientSecret= # Client secret
connections__serviceConnection__settings__tenantId= # Tenant ID

connectionsMap__0__connection=serviceConnection
connectionsMap__0__serviceUrl=*

# GitHub OAuth handler — configure an Azure Bot OAuth Connection with GitHub as the provider
AgentApplication__UserAuthorization__AutoSignin=true
AgentApplication__UserAuthorization__DefaultHandlerName=github
AgentApplication__UserAuthorization__Handlers__github__Settings__title=Sign in with GitHub
AgentApplication__UserAuthorization__Handlers__github__Settings__text=Please sign in to your GitHub account to use the Dungeon Scribe
AgentApplication__UserAuthorization__Handlers__github__Settings__azureBotOAuthConnectionName= # the connection name configured in Azure Bot for GitHub OAuth

# Optional: Override the default model (gpt-4.1)
# COPILOT_MODEL=gpt-4.1

DEBUG=agents:*:error